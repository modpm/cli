{
  "name": "@modpm/cli",
  "version": "0.0.0-dev",
  "license": "GPL-3.0",
  "imports": {
    "libmodpm": "npm:libmodpm@^0.2.0"
  },
  "exports": {},
  "tasks": {
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": false,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false
  }
}
